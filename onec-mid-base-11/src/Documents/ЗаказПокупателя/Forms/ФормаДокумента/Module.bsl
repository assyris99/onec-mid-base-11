
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму документа контактное лицо. 
	КонтактноеЛицо = Элементы.Добавить("КонтактноеЛицо", Тип("ПолеФормы"), Элементы.ГруппаШапкаПраво);
	КонтактноеЛицо.Вид = ВидПоляФормы.ПолеВвода;
	КонтактноеЛицо.ПутьКДанным = "Объект.ББ_КонтактноеЛицо";
	// -- Б.И. Бондарь. 26.02.2026
	
	
	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму согласованную скидку и команду пересчета по скидке.
	// Добавляем группу "Скидка" для добавления туда %скидки и кнопки пересчета.
	ГруппаСкидка = Элементы.Добавить("ГруппаСкидка", Тип("ГруппаФормы"), Элементы.ГруппаШапкаЛево);
	ГруппаСкидка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаСкидка.Заголовок = "Скидка";
	
	// Выводим на форму скидку. 
	СогласованнаяСкидка = Элементы.Добавить("СогласованнаяСкидка", Тип("ПолеФормы"), Элементы.ГруппаСкидка);
	СогласованнаяСкидка.Вид = ВидПоляФормы.ПолеВвода;
	СогласованнаяСкидка.ПутьКДанным = "Объект.ББ_СогласованнаяСкидка";
	// При изменении лежит в области "Доработка конфигурации".
	СогласованнаяСкидка.УстановитьДействие("ПриИзменении", "ББ_СогласованнаяСкидкаПриИзменении");
	
	//Добавляем команду пересчета скидки.
	КомандаПересчитать = Команды.Добавить("ПересчитатьСкидку");
	КомандаПересчитать.Заголовок = "Пересчитать скидку";
	КомандаПересчитать.Действие = "ББ_КомандаПересчитать";
	
	КнопкаКоманды = Элементы.Добавить("ПересчитатьСкидку", Тип("КнопкаФормы"), Элементы.ГруппаСкидка);
	КнопкаКоманды.ИмяКоманды = "ПересчитатьСкидку";
	КнопкаКоманды.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	// -- Б.И. Бондарь. 26.02.2026
	
КонецПроцедуры

