#Область ДоработкиКонфигурации

&НаКлиенте
Процедура ББ_СогласованнаяСкидкаПриИзменении(Элемент)
	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму согласованную скидку и команду пересчета по скидке.
	// В соответствии с ТЗ добавлен автозапрос на перерасчет таблиц при изменении значения %скидки.
	Если Объект.Товары.Количество() <> 0 ИЛИ Объект.Услуги.Количество() <> 0 Тогда
		ББ_ЗадатьВопрос()
	КонецЕсли;
	// -- Б.И. Бондарь. 26.02.2026.
КонецПроцедуры

&НаКлиенте
Асинх Процедура ББ_ЗадатьВопрос() 
	
	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму согласованную скидку и команду пересчета по скидке.
	// Прописан обработчик в случае, если при изменении %скидки по запросу на перерасчет будет получен ответ "Да".
	ТекстВопроса = ?(Объект.ББ_СогласованнаяСкидка = 0, 
		"Сбросить скидку и пересчитать табличную часть на базовые цены?", 
		"Пересчитать табличную часть с учетом новой скидки?");
	Обещание = ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);
	Результат = Ждать Обещание;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ББ_ПересчитатьСкидку();
	КонецЕсли;
	// -- Б.И. Бондарь. 26.02.2026. 
КонецПроцедуры

&НаКлиенте
Процедура ББ_КомандаПересчитать(Команда)

	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму согласованную скидку и команду пересчета по скидке.
	// Прописан обработчик события нажатия на кнопку "Пересчитать скидку".
	ББ_ПересчитатьСкидку();
	// -- Б.И. Бондарь. 26.02.2026. 
	
КонецПроцедуры

&НаКлиенте
Процедура ББ_ПересчитатьСкидку()
	
	// ++ Б.И. Бондарь. 26.02.2026. Вывести на форму согласованную скидку и команду пересчета по скидке.
	// Обработчки события нажатия на кнопку пересчета скидки или согласия на пересчет скидки при изменении %скидки. 
	Для каждого Строка Из Объект.Товары Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;
	
	Для каждого Строка Из Объект.Услуги Цикл
		РассчитатьСуммуСтроки(Строка);
	КонецЦикла;

	РассчитатьСуммуДокумента();
	// --Б.И. Бондарь. 26.02.2026. 
	
КонецПроцедуры

#КонецОбласти
